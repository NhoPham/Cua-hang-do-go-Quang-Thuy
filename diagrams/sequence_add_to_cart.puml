@startuml Sequence Diagram - Quy trình Thêm sản phẩm vào giỏ hàng
participant "👤 Khách hàng" as Customer
participant "🌐 Trình duyệt" as Browser
participant "📱 Cart Controller" as CartController
participant "💾 Database" as Database

Customer -> Browser: Xem chi tiết sản phẩm\nBấm 'Thêm vào giỏ'
activate Browser
note over Browser
    Gửi: ProductId, Quantity, ReturnUrl (tùy chọn)
end note

Browser -> CartController: POST /Cart/Add\n(productId, quantity, returnUrl)
activate CartController

CartController -> CartController: 🔐 Kiểm tra quyền (IsAuthorized)
alt Người dùng chưa đăng nhập
    CartController -->> Browser: Redirect đăng nhập
    deactivate CartController
else OK - Đã đăng nhập
    
    CartController -> CartController: 📝 Lấy UserId từ Claims
    CartController -> CartController: ✅ Validate:\n- Qty > 0?\n- Nếu qty < 1 thì set = 1
    
    CartController -> Database: SELECT Product\nWHERE Id = ?
    activate Database
    Database -->> CartController: Product
    deactivate Database
    
    alt Không tìm thấy sản phẩm
        CartController -->> Browser: ErrorMessage: "Không tìm sản phẩm"
        CartController -->> Browser: Redirect /Product/Index
        deactivate CartController
        Browser -->> Customer: ❌ Lỗi không tìm thấy sản phẩm
    else Tìm thấy sản phẩm
        
        CartController -> CartController: 🏪 Kiểm tra Stock
        alt Stock <= 0
            CartController -->> Browser: ErrorMessage: "Sản phẩm hết hàng"
            CartController -->> Browser: RedirectBack(returnUrl)
            deactivate CartController
            Browser -->> Customer: ❌ Sản phẩm đã hết hàng
        else Stock > 0
            
            CartController -> Database: SELECT CartItem\nWHERE UserId = ? AND ProductId = ?
            activate Database
            Database -->> CartController: CartItem (hoặc null)
            deactivate Database
            
            alt CartItem không tồn tại
                note over CartController
                    Thêm CartItem mới
                end note
                CartController -> Database: INSERT INTO CartItems\n(UserId, ProductId, Quantity, UnitPrice, CreatedAt)
                activate Database
                Database -->> CartController: ✅ Success
                deactivate Database
            else CartItem đã tồn tại
                note over CartController
                    Cộng thêm số lượng
                    Qty = Min(Qty + Request.Qty, Product.Stock)
                end note
                CartController -> Database: UPDATE CartItems\nSET Quantity = ?,\nUnitPrice = Product.Price\nWHERE Id = ?
                activate Database
                Database -->> CartController: ✅ Success
                deactivate Database
            end
            
            CartController -> Database: COMMIT/SaveChanges
            
            CartController -->> Browser: SuccessMessage:\n"Đã thêm sản phẩm vào giỏ hàng"
            CartController -->> Browser: RedirectBack(returnUrl)
            
            deactivate CartController
            Browser -->> Customer: ✅ Thêm thành công\nQuay lại trang sản phẩm
            
            note over Customer
                ✅ Dã thêm vào giỏ!
                - Sản phẩm sẽ hiển thị trong Cart
                - Có thể tiếp tục mua hàng
                - Hoặc đi tới giỏ hàng để thanh toán
            end note
        end
    end
end

@enduml

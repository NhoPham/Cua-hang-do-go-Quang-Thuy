@startuml Sequence Diagram - Quy trình Admin cập nhật trạng thái đơn hàng
participant "👨‍💼 Admin" as Admin
participant "🌐 Trình duyệt" as Browser
participant "📱 Order Controller" as OrderController
participant "💾 Database" as Database

Admin -> Browser: Vào admin panel\nChọn đơn hàng\nXem chi tiết đơn
activate Browser

Browser -> OrderController: GET /Order/Details\n(orderId)
activate OrderController

OrderController -> OrderController: 🔐 Kiểm tra quyền (IsAdmin)
alt Không phải admin
    OrderController -->> Browser: Forbid/403
    deactivate OrderController
else OK - Là admin
    OrderController -> Database: SELECT Order\nINCLUDE Items
    activate Database
    Database -->> OrderController: Order details
    deactivate Database
    
    OrderController -->> Browser: Render trang chi tiết đơn hàng
    deactivate OrderController
    Browser -->> Admin: Hiển thị form:\n- Trạng thái đơn: Pending/Confirmed/Delivered/Cancelled\n- Trạng thái thanh toán: Pending/Paid/Failed
end

Admin -> Browser: Chọn trạng thái mới\nBấm 'Cập nhật'
Browser -> OrderController: POST /Order/UpdateStatus\n(orderId, orderStatus, paymentStatus)
activate OrderController

OrderController -> OrderController: ✅ Validate:\n- orderStatus hợp lệ?\n- paymentStatus hợp lệ?
alt Validation fail
    OrderController -->> Browser: ErrorMessage
    deactivate OrderController
    Browser -->> Admin: Hiển thị lỗi
else Validation OK
    
    OrderController -> OrderController: 🔐 Kiểm tra quyền (IsAdmin)
    
    OrderController -> Database: SELECT Order\nINCLUDE Items, Products
    activate Database
    Database -->> OrderController: Order + Items + Products
    deactivate Database
    
    alt Order === Cancelled
        alt newStatus !== Cancelled
            OrderController -->> Browser: ErrorMessage:\n"Đơn đã hủy không thể chuyển sang trạng thái khác"
            deactivate OrderController
            Browser -->> Admin: ❌ Lỗi
        end
    end
    
    OrderController -> Database: BEGIN TRANSACTION
    activate Database
    
    alt oldOrderStatus !== Cancelled AND newOrderStatus === Cancelled
        note over OrderController
            Đơn đang được hủy
            → Hoàn kho tất cả sản phẩm
        end note
        
        loop Mỗi OrderItem
            OrderController -> Database: UPDATE Product\nSET Stock = Stock + Quantity\nWHERE Id = ?
            
            OrderController -> Database: INSERT INTO InventoryTransactions\n(ProductId, QtyChanged, Type='CANCEL_RETURN', Note...)
        end
    end
    
    OrderController -> Database: UPDATE Order\nSET OrderStatus = ?,\nPaymentStatus = ?,\nUpdatedAt = NOW()
    
    OrderController -> Database: COMMIT TRANSACTION
    deactivate Database
    
    OrderController -->> Browser: SuccessMessage:\n"Đã cập nhật trạng thái đơn hàng"
    deactivate OrderController
    
    Browser -->> Admin: ✅ Cập nhật thành công\nQuay lại xem chi tiết
    
    note over Admin
        ✅ Đơn hàng đã được cập nhật!
        Trạng thái mới:
        - Đơn: Confirmed/Delivered/Cancelled
        - Thanh toán: Paid/Pending/Failed
        
        Ghi chú: Nếu hủy đơn
        → Tự động hoàn lại toàn bộ stock
    end note
end

@enduml

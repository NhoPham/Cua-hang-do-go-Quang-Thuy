@startuml Sequence Diagram - Quy trình Đăng nhập
participant "👤 Khách hàng" as Customer
participant "🌐 Trình duyệt" as Browser
participant "📱 Auth Controller" as AuthController
participant "🔧 Password Helper" as PasswordHelper
participant "💾 Database" as Database

Customer -> Browser: Truy cập trang Đăng nhập
activate Browser
Browser -->> Customer: Hiển thị form đăng nhập

Customer -> Browser: Nhập Username/Email + Password
Browser -> AuthController: POST /Account/Login\n(LoginViewModel)
activate AuthController

AuthController -> AuthController: ✅ Kiểm tra ModelState
alt ModelState không hợp lệ
    AuthController -->> Browser: Render form + lỗi validation
    deactivate AuthController
    Browser -->> Customer: Hiển thị lỗi
else OK - ModelState hợp lệ
    
    AuthController -> Database: SELECT User\nWHERE Username/Email = ?
    activate Database
    Database -->> AuthController: User record (hoặc null)
    deactivate Database
    
    alt Không tìm thấy user
        AuthController -->> Browser: Render form\n+ lỗi "Tài khoản/mật khẩu sai"
        deactivate AuthController
        Browser -->> Customer: Hiển thị lỗi
    else Tìm thấy user
        
        AuthController -> PasswordHelper: VerifyPassword\n(inputPassword, hashedPassword)
        activate PasswordHelper
        PasswordHelper -> PasswordHelper: 🔐 So sánh hash password\nhoặc so sánh plain text (legacy)
        PasswordHelper -->> AuthController: boolean (match/không match)
        deactivate PasswordHelper
        
        alt Password không đúng
            AuthController -->> Browser: Render form\n+ lỗi "Tài khoản/mật khẩu sai"
            deactivate AuthController
            Browser -->> Customer: Hiển thị lỗi
        else Password đúng
            
            AuthController -> AuthController: Kiểm tra: Password có phải plain text (legacy)?
            alt Có - cần hash lại
                AuthController -> PasswordHelper: HashPassword(plainPassword)
                activate PasswordHelper
                PasswordHelper -->> AuthController: hashedPassword
                deactivate PasswordHelper
                
                AuthController -> Database: UPDATE User\nSET Password = ?\nWHERE Id = ?
                activate Database
                Database -->> AuthController: ✅ OK
                deactivate Database
            else Không - đã hashed rồi
                note over AuthController
                    Skip re-hash
                end note
            end
            
            AuthController -> AuthController: 🎫 Tạo Claims Principal\n(UserId, Username, Email, Role)
            AuthController -> AuthController: ☑️ SignIn với\nCookieAuthenticationScheme
            
            AuthController -> AuthController: ✅ Kiểm tra RememberMe
            alt RememberMe = true
                AuthController -> AuthController: Set cookie expiry = 7 days
            else RememberMe = false
                AuthController -> AuthController: Set cookie hết hạn khi đóng trình duyệt
            end
            
            AuthController -> AuthController: 🔄 Kiểm tra ReturnUrl
            alt ReturnUrl hợp lệ (local URL)
                AuthController -->> Browser: LocalRedirect(returnUrl)
            else ReturnUrl không hợp lệ
                AuthController -->> Browser: Redirect /Home/Index
            end
            
            deactivate AuthController
            Browser -->> Customer: ✅ Đăng nhập thành công\nChuyển hướng tới trang yêu cầu
            
            note over Customer
                ✅ Bạn đã đăng nhập!
                - Session được lưu trong cookie
                - Có thể truy cập giỏ hàng, đơn hàng, v.v.
                - Nếu là admin: Access admin features
            end note
        end
    end
end

@enduml

@{
    ViewData["Title"] = "Giới thiệu chúng tôi";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="fw-bold">@ViewData["Title"]</h1>
        <p class="text-muted fs-5">Cửa hàng đồ gỗ Quảng Thủy</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card shadow-sm border-0 rounded-4 p-4">
                <h3 class="mb-3">Về chúng tôi</h3>
                <p>
                    Cửa hàng đồ gỗ Quảng Thủy chuyên cung cấp các sản phẩm đồ gỗ và nội thất
                    phục vụ cho gia đình, văn phòng và nhiều không gian sinh hoạt khác.
                    Chúng tôi mong muốn mang đến cho khách hàng những sản phẩm vừa đảm bảo tính thẩm mỹ,
                    vừa đáp ứng nhu cầu sử dụng lâu dài.
                </p>

                <h3 class="mt-4 mb-3">Sản phẩm kinh doanh</h3>
                <p>
                    Cửa hàng hiện cung cấp nhiều mặt hàng như bàn, ghế, tủ, giường, kệ và các sản phẩm nội thất bằng gỗ.
                    Các sản phẩm được lựa chọn theo tiêu chí bền đẹp, phù hợp với nhu cầu thực tế
                    và đa dạng về mẫu mã.
                </p>

                <h3 class="mt-4 mb-3">Cam kết của chúng tôi</h3>
                <p>
                    Cửa hàng đồ gỗ Quảng Thủy luôn đặt sự hài lòng của khách hàng lên hàng đầu.
                    Chúng tôi cam kết mang đến sản phẩm chất lượng, thông tin rõ ràng
                    và dịch vụ hỗ trợ tận tình để khách hàng có thể yên tâm khi lựa chọn sản phẩm.
                </p>
            </div>
        </div>
    </div>
</div>
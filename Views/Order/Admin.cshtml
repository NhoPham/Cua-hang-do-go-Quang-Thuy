@model IEnumerable<Order>

@{
    ViewData["Title"] = "Quản lý đơn hàng";
}

<h1 class="fw-bold mb-3">Quản lý đơn hàng</h1>
<p class="text-muted mb-4">Admin có thể xem danh sách đơn, trạng thái xử lý và thanh toán.</p>

<div class="card border-0 shadow-sm rounded-4">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Mã đơn</th>
                    <th>Khách hàng</th>
                    <th>Ngày tạo</th>
                    <th>Trạng thái</th>
                    <th>Thanh toán</th>
                    <th class="text-end">Tổng tiền</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td class="fw-semibold">@order.OrderCode</td>
                        <td>
                            <div>@order.ReceiverName</div>
                            <div class="small text-muted">@order.Email</div>
                        </td>
                        <td>@order.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <span class="badge @OrderUiHelper.OrderStatusBadgeClass(order.OrderStatus)">
                                @OrderUiHelper.OrderStatusLabel(order.OrderStatus)
                            </span>
                        </td>
                        <td>
                            <span class="badge @OrderUiHelper.PaymentStatusBadgeClass(order.PaymentStatus)">
                                @OrderUiHelper.PaymentStatusLabel(order.PaymentStatus)
                            </span>
                        </td>
                        <td class="text-end fw-semibold">@order.TotalAmount.ToString("N0") đ</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-dark">Xem</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@model IEnumerable<Order>

@{
    ViewData["Title"] = "Đơn của tôi";
}

<h1 class="fw-bold mb-3">Đơn của tôi</h1>
<p class="text-muted mb-4">Theo dõi lịch sử mua hàng và trạng thái xử lý đơn.</p>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <h5 class="mb-2">Bạn chưa có đơn hàng nào.</h5>
            <a asp-controller="Product" asp-action="Index" class="btn btn-primary mt-2">Bắt đầu mua sắm</a>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm rounded-4">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Mã đơn</th>
                        <th>Ngày tạo</th>
                        <th>Thanh toán</th>
                        <th>Trạng thái</th>
                        <th class="text-end">Tổng tiền</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@order.OrderCode</td>
                            <td>@order.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <span class="badge @OrderUiHelper.PaymentStatusBadgeClass(order.PaymentStatus)">
                                    @OrderUiHelper.PaymentStatusLabel(order.PaymentStatus)
                                </span>
                            </td>
                            <td>
                                <span class="badge @OrderUiHelper.OrderStatusBadgeClass(order.OrderStatus)">
                                    @OrderUiHelper.OrderStatusLabel(order.OrderStatus)
                                </span>
                            </td>
                            <td class="text-end fw-semibold">@order.TotalAmount.ToString("N0") đ</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-dark">Chi tiết</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

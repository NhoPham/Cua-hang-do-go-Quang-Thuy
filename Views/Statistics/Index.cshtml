@model StatisticsDashboardViewModel

@{
    ViewData["Title"] = "Thống kê";
}

<h1 class="fw-bold mb-3">Thống kê bán hàng</h1>
<p class="text-muted mb-4">Theo dõi doanh thu, đơn hàng, sản phẩm bán chạy và cảnh báo tồn kho.</p>

<form method="get" class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body row g-3 align-items-end">
        <div class="col-md-4">
            <label class="form-label">Từ ngày</label>
            <input type="date" name="from" value="@Model.From.ToString("yyyy-MM-dd")" class="form-control" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Đến ngày</label>
            <input type="date" name="to" value="@Model.To.ToString("yyyy-MM-dd")" class="form-control" />
        </div>
        <div class="col-md-4 d-grid">
            <button class="btn btn-primary">Lọc thống kê</button>
        </div>
    </div>
</form>

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body">
                <div class="text-muted">Tổng đơn hàng</div>
                <div class="fs-2 fw-bold">@Model.TotalOrders</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body">
                <div class="text-muted">Đơn chờ xác nhận</div>
                <div class="fs-2 fw-bold">@Model.PendingOrders</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body">
                <div class="text-muted">Đơn hoàn thành</div>
                <div class="fs-2 fw-bold">@Model.CompletedOrders</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body">
                <div class="text-muted">Doanh thu</div>
                <div class="fs-4 fw-bold text-danger">@Model.TotalRevenue.ToString("N0") đ</div>
                <div class="small text-muted">Đã bán @Model.TotalUnitsSold sản phẩm</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body">
                <h4 class="fw-bold mb-3">Top sản phẩm bán chạy</h4>
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Sản phẩm</th>
                                <th class="text-end">SL bán</th>
                                <th class="text-end">Doanh thu</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.TopProducts)
                            {
                                <tr>
                                    <td>@item.ProductName</td>
                                    <td class="text-end">@item.QuantitySold</td>
                                    <td class="text-end">@item.Revenue.ToString("N0") đ</td>
                                </tr>
                            }
                            @if (!Model.TopProducts.Any())
                            {
                                <tr>
                                    <td colspan="3" class="text-center text-muted">Chưa có dữ liệu.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body">
                <h4 class="fw-bold mb-3">Phân bố trạng thái đơn</h4>
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Trạng thái</th>
                                <th class="text-end">Số lượng</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.StatusBreakdown)
                            {
                                <tr>
                                    <td>@OrderUiHelper.OrderStatusLabel(item.Status)</td>
                                    <td class="text-end">@item.Count</td>
                                </tr>
                            }
                            @if (!Model.StatusBreakdown.Any())
                            {
                                <tr>
                                    <td colspan="2" class="text-center text-muted">Chưa có dữ liệu.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <h5 class="fw-bold mt-4 mb-3">Sản phẩm sắp hết hàng</h5>
                <ul class="list-group list-group-flush">
                    @if (Model.LowStockProducts.Any())
                    {
                        @foreach (var item in Model.LowStockProducts)
                        {
                            <li class="list-group-item px-0 d-flex justify-content-between">
                                <span>@item.ProductName</span>
                                <span class="badge bg-danger">@item.Stock</span>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="list-group-item px-0 text-muted">Không có sản phẩm nào dưới ngưỡng cảnh báo.</li>
                    }
                </ul>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">
                <h4 class="fw-bold mb-3">Doanh thu theo ngày</h4>
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Ngày</th>
                                <th class="text-end">Số đơn</th>
                                <th class="text-end">Doanh thu</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.RevenueByDay)
                            {
                                <tr>
                                    <td>@item.Date.ToString("dd/MM/yyyy")</td>
                                    <td class="text-end">@item.Orders</td>
                                    <td class="text-end">@item.Revenue.ToString("N0") đ</td>
                                </tr>
                            }
                            @if (!Model.RevenueByDay.Any())
                            {
                                <tr>
                                    <td colspan="3" class="text-center text-muted">Chưa có dữ liệu doanh thu trong khoảng thời gian này.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

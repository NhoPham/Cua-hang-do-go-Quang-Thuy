@model CartViewModel

@{
    ViewData["Title"] = "Giỏ hàng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="fw-bold mb-1">Giỏ hàng</h1>
        <p class="text-muted mb-0">Kiểm tra lại sản phẩm trước khi thanh toán.</p>
    </div>
    <a asp-controller="Product" asp-action="Index" class="btn btn-outline-dark">Tiếp tục mua</a>
</div>

@if (!Model.Items.Any())
{
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <h5 class="mb-2">Giỏ hàng của bạn đang trống.</h5>
            <p class="text-muted mb-3">Hãy quay lại trang sản phẩm để thêm món hàng bạn muốn mua.</p>
            <a asp-controller="Product" asp-action="Index" class="btn btn-primary">Xem sản phẩm</a>
        </div>
    </div>
}
else
{
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Sản phẩm</th>
                                <th class="text-end">Đơn giá</th>
                                <th class="text-center">Số lượng</th>
                                <th class="text-end">Thành tiền</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            <img src="@item.ProductImage" alt="@item.ProductName" class="rounded-3 border" style="width: 72px; height: 72px; object-fit: cover;" />
                                            <div>
                                                <div class="fw-semibold">@item.ProductName</div>
                                                <div class="text-muted small">Tồn kho tối đa: @item.MaxStock</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-end">@item.UnitPrice.ToString("N0") đ</td>
                                    <td class="text-center" style="min-width: 180px;">
                                        <form asp-action="UpdateQuantity" method="post" class="d-flex gap-2 justify-content-center">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.CartItemId" />
                                            <input type="number" name="quantity" value="@item.Quantity" min="1" max="@Math.Max(item.MaxStock, 1)" class="form-control form-control-sm" style="width: 84px;" />
                                            <button class="btn btn-sm btn-outline-dark" type="submit">Cập nhật</button>
                                        </form>
                                    </td>
                                    <td class="text-end fw-semibold">@item.SubTotal.ToString("N0") đ</td>
                                    <td class="text-end">
                                        <form asp-action="Remove" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.CartItemId" />
                                            <button class="btn btn-sm btn-outline-danger" type="submit">Xóa</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <form asp-action="Clear" method="post" class="mt-3">
                @Html.AntiForgeryToken()
                <button class="btn btn-outline-danger" type="submit">Xóa toàn bộ giỏ hàng</button>
            </form>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h4 class="fw-bold mb-3">Tóm tắt đơn hàng</h4>

                    <div class="d-flex justify-content-between mb-2">
                        <span>Số sản phẩm</span>
                        <strong>@Model.Items.Sum(x => x.Quantity)</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span>Tạm tính</span>
                        <strong class="text-danger">@Model.TotalAmount.ToString("N0") đ</strong>
                    </div>

                    <div class="alert alert-info small">
                        Phí vận chuyển sẽ được xác nhận ở bước thanh toán.
                    </div>

                    <div class="d-grid gap-2">
                        <a asp-controller="Order" asp-action="Checkout" class="btn btn-primary btn-lg">Tiến hành thanh toán</a>
                        <a asp-controller="Product" asp-action="Index" class="btn btn-outline-dark">Mua thêm</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@model IEnumerable<QLBH.ViewModels.AdminCustomerViewModel>

@{
    ViewData["Title"] = "Quản lý khách hàng";

    var keyword = ViewBag.Keyword as string;
    var roleFilter = ViewBag.RoleFilter as string;
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
        <h1 class="fw-bold mb-1">Quản lý khách hàng</h1>
        <p class="text-muted mb-0">Tìm kiếm tài khoản, lọc vai trò và cập nhật quyền truy cập.</p>
    </div>
</div>

<form method="get" class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-4">
        <div class="row g-3 align-items-end">
            <div class="col-lg-6">
                <label class="form-label fw-semibold">Tìm theo tên đăng nhập hoặc email</label>
                <input type="text"
                       name="keyword"
                       value="@keyword"
                       class="form-control rounded-3"
                       placeholder="Nhập username hoặc email..." />
            </div>

            <div class="col-lg-3">
                <label class="form-label fw-semibold">Vai trò</label>
                <select name="roleFilter" class="form-select rounded-3">
                    <option value="">Tất cả</option>
                    <option value="customer" selected="@(roleFilter == "customer" ? "selected" : null)">Khách hàng</option>
                    <option value="admin" selected="@(roleFilter == "admin" ? "selected" : null)">Admin</option>
                </select>
            </div>

            <div class="col-lg-3">
                <div class="d-grid d-md-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-fill rounded-3">Lọc</button>
                    <a asp-action="Customers" class="btn btn-outline-secondary flex-fill rounded-3">Đặt lại</a>
                </div>
            </div>
        </div>
    </div>
</form>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Tài khoản</th>
                        <th>Email</th>
                        <th>Số đơn</th>
                        <th>Tổng chi tiêu</th>
                        <th>Vai trò</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-semibold">#@item.Id</td>

                                <td>
                                    <div class="fw-semibold">@item.Username</div>
                                </td>

                                <td>@item.Email</td>

                                <td>@item.OrderCount</td>

                                <td class="fw-semibold text-danger">@item.TotalSpent.ToString("N0") đ</td>

                                <td>
                                    @if (item.Role == "admin")
                                    {
                                        <span class="badge bg-dark px-3 py-2">Admin</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary px-3 py-2">Khách hàng</span>
                                    }
                                </td>

                                <td class="text-end pe-4">
                                    <form asp-action="UpdateCustomerRole" method="post" class="d-inline-flex gap-2 align-items-center">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="keyword" value="@keyword" />
                                        <input type="hidden" name="roleFilter" value="@roleFilter" />

                                        <select name="role" class="form-select form-select-sm rounded-3" style="min-width: 130px;">
                                            <option value="customer" selected="@(item.Role == "customer" ? "selected" : null)">Khách hàng</option>
                                            <option value="admin" selected="@(item.Role == "admin" ? "selected" : null)">Admin</option>
                                        </select>

                                        <button type="submit" class="btn btn-sm btn-primary rounded-3">
                                            Lưu
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                Không tìm thấy tài khoản phù hợp.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
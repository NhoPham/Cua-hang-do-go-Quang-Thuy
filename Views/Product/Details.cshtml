@model Product

@{
    ViewData["Title"] = "Chi tiết sản phẩm";
    var imageList = ImageHelper.GetImageList(Model.Images);
    var mainImage = imageList.FirstOrDefault() ?? "/images/default/no-image.jpg";
}

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <img src="@mainImage" alt="@Model.Name" class="w-100" style="height: 420px; object-fit: cover;" />
        </div>

        @if (imageList.Count > 1)
        {
            <div class="row row-cols-4 g-2 mt-2">
                @foreach (var img in imageList)
                {
                    <div class="col">
                        <img src="@img" alt="Ảnh sản phẩm" class="img-fluid rounded-3 border" style="height: 90px; width: 100%; object-fit: cover;" />
                    </div>
                }
            </div>
        }
    </div>

    <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <div class="text-muted mb-2">Danh mục: @(Model.Category?.Name ?? "Chưa phân loại")</div>
                <h1 class="fw-bold">@Model.Name</h1>
                <div class="fs-3 fw-bold text-danger my-3">@Model.Price.ToString("N0") đ</div>
                <p class="mb-2">
                    <span class="badge @(Model.Stock > 0 ? "bg-success" : "bg-danger")">
                        @(Model.Stock > 0 ? "Còn hàng" : "Hết hàng")
                    </span>
                </p>
                <p class="text-muted">Số lượng tồn kho: @Model.Stock</p>

                <h5 class="mt-4">Mô tả</h5>
                <p class="text-muted">@(string.IsNullOrWhiteSpace(Model.Description) ? "Chưa có mô tả sản phẩm." : Model.Description)</p>

                <div class="d-grid gap-2 mt-4">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <form asp-controller="Cart" asp-action="Add" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@Model.Id" />
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                            <div class="row g-2">
                                <div class="col-4">
                                    <input type="number" name="quantity" value="1" min="1" max="@Math.Max(Model.Stock, 1)" class="form-control" />
                                </div>
                                <div class="col-8 d-grid">
                                    <button class="btn btn-primary" type="submit" @(Model.Stock <= 0 ? "disabled" : null)>
                                        @(Model.Stock > 0 ? "Thêm vào giỏ hàng" : "Tạm hết hàng")
                                    </button>
                                </div>
                            </div>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@Context.Request.Path" class="btn btn-primary">
                            Đăng nhập để mua hàng
                        </a>
                    }

                    <a asp-action="Index" class="btn btn-outline-dark">Quay lại danh sách</a>

                    @if (User.IsInRole("admin"))
                    {
                        <div class="d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning w-50">Chỉnh sửa</a>
                            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger w-50">Xóa</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const images = document.querySelectorAll('.row-cols-4 .col img');
        const mainImage = document.querySelector('.col-lg-6:first-child img');
        let currentIndex = 0;

        if (images.length > 1) {
            setInterval(function() {
                currentIndex = (currentIndex + 1) % images.length;
                mainImage.src = images[currentIndex].src;
            }, 3000);
        }
    });
</script>
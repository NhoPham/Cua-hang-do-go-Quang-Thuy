@model QLBH.Models.Product
@using QLBH.Utils

@{
    ViewData["Title"] = "Chỉnh sửa sản phẩm";

    // ===== ĐÃ SỬA: dùng helper để lấy danh sách ảnh hiện tại =====
    var imageList = ImageHelper.GetImageList(Model.Images);
}

<div class="container py-4">
    @* ===== ĐÃ SỬA: phần header trang ===== *@
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h1 class="fw-bold mb-1">Chỉnh sửa sản phẩm</h1>
            <p class="text-muted mb-0">Cập nhật thông tin, giá bán, tồn kho và hình ảnh sản phẩm.</p>
        </div>

        <a asp-action="Index" class="btn btn-outline-secondary rounded-3">
            ← Quay lại danh sách
        </a>
    </div>

    <form asp-action="Edit" enctype="multipart/form-data" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-4"></div>

        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="Images" />

        <div class="row g-4">
            @* ===== ĐÃ SỬA: chuyển cột ảnh hiện tại sang bên trái ===== *@
            <div class="col-lg-5">
                <div class="card border-0 shadow-sm rounded-4 mb-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-1">Ảnh hiện tại</h5>
                        <p class="text-muted mb-3">Danh sách hình ảnh đang được lưu cho sản phẩm này.</p>

                        @if (imageList.Any())
                        {
                            <div class="row g-3">
                                @foreach (var img in imageList)
                                {
                                    <div class="col-6">
                                        <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                                            <img src="@img"
                                                 alt="Hình ảnh sản phẩm"
                                                 class="w-100"
                                                 style="height: 180px; object-fit: cover;" />
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="border rounded-4 p-4 text-center text-muted bg-light-subtle">
                                Chưa có hình ảnh hiện tại.
                            </div>
                        }
                    </div>
                </div>

                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3">Thông tin hiện tại</h5>

                        <div class="border rounded-4 p-3 mb-3 bg-light-subtle">
                            <div class="text-muted small mb-1">Tên sản phẩm hiện tại</div>
                            <div class="fw-semibold">@Model.Name</div>
                        </div>

                        <div class="border rounded-4 p-3 mb-3 bg-light-subtle">
                            <div class="text-muted small mb-1">Giá hiện tại</div>
                            <div class="fw-bold text-danger">
                                @Model.Price.ToString("N0") đ
                            </div>
                        </div>

                        <div class="border rounded-4 p-3 mb-3 bg-light-subtle">
                            <div class="text-muted small mb-1">Tồn kho hiện tại</div>
                            <div class="fw-semibold">@Model.Stock</div>
                        </div>

                        <div class="border rounded-4 p-3 bg-light-subtle">
                            <div class="text-muted small mb-1">Số lượng ảnh hiện tại</div>
                            <div class="fw-semibold">@imageList.Count ảnh</div>
                        </div>
                    </div>
                </div>
            </div>

            @* ===== ĐÃ SỬA: chuyển form chỉnh sửa sang bên phải ===== *@
            <div class="col-lg-7">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-4 p-lg-5">
                        <div class="mb-4">
                            <h4 class="fw-bold mb-1">Thông tin sản phẩm</h4>
                            <p class="text-muted mb-0">Điền đầy đủ thông tin để sản phẩm hiển thị đẹp và chính xác hơn.</p>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-semibold">Tên sản phẩm</label>
                            <input asp-for="Name" class="form-control rounded-3" placeholder="Nhập tên sản phẩm" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-semibold">Mô tả sản phẩm</label>
                            <textarea asp-for="Description" class="form-control rounded-3" rows="5" placeholder="Nhập mô tả sản phẩm"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Price" class="form-label fw-semibold">Giá bán</label>
                                <input asp-for="Price" class="form-control rounded-3" placeholder="Nhập giá sản phẩm" />
                                <span asp-validation-for="Price" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Stock" class="form-label fw-semibold">Số lượng tồn kho</label>
                                <input asp-for="Stock" class="form-control rounded-3" placeholder="Nhập số lượng tồn kho" />
                                <span asp-validation-for="Stock" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mt-3 mb-3">
                            <label asp-for="CategoryId" class="form-label fw-semibold">Danh mục sản phẩm</label>
                            <select asp-for="CategoryId" class="form-select rounded-3" asp-items="ViewBag.CategoryId">
                                <option value="">-- Chọn danh mục --</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger small"></span>
                        </div>

                        <div class="border rounded-4 p-3 p-md-4 bg-light-subtle mb-3">
                            <label for="NewImages" class="form-label fw-semibold mb-2">Chọn hình ảnh mới</label>
                            <input type="file"
                                   id="NewImages"
                                   name="NewImages"
                                   class="form-control rounded-3"
                                   multiple
                                   accept="image/*" />

                            <div class="form-text mt-2">
                                Nếu không chọn ảnh mới, hệ thống sẽ giữ nguyên ảnh hiện tại.
                            </div>
                        </div>

                        <div class="mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h6 class="fw-bold mb-0">Xem trước ảnh mới</h6>
                                <span id="previewCount" class="badge text-bg-primary rounded-pill">0 ảnh</span>
                            </div>

                            <div id="previewImages" class="row g-3"></div>
                        </div>

                        <div class="d-flex flex-column flex-sm-row gap-2 pt-2">
                            <button type="submit" class="btn btn-primary px-4 rounded-3">
                                Cập nhật sản phẩm
                            </button>

                            <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-3">
                                Hủy
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const input = document.getElementById('NewImages');
            const preview = document.getElementById('previewImages');
            const previewCount = document.getElementById('previewCount');

            if (!input || !preview || !previewCount) return;

            input.addEventListener('change', function (e) {
                preview.innerHTML = '';

                const files = Array.from(e.target.files || []);
                previewCount.textContent = files.length + ' ảnh';

                if (files.length === 0) {
                    preview.innerHTML = `
                        <div class="col-12">
                            <div class="border rounded-4 p-4 text-center text-muted bg-light-subtle">
                                Chưa chọn ảnh mới.
                            </div>
                        </div>
                    `;
                    return;
                }

                files.forEach(function (file) {
                    const reader = new FileReader();

                    reader.onload = function (event) {
                        const col = document.createElement('div');
                        col.className = 'col-6 col-md-4';

                        col.innerHTML = `
                            <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                                <img src="${event.target.result}"
                                     alt="Preview"
                                     class="w-100"
                                     style="height: 180px; object-fit: cover;" />
                                <div class="card-body p-2">
                                    <div class="small text-truncate" title="${file.name}">${file.name}</div>
                                </div>
                            </div>
                        `;

                        preview.appendChild(col);
                    };

                    reader.readAsDataURL(file);
                });
            });

            preview.innerHTML = `
                <div class="col-12">
                    <div class="border rounded-4 p-4 text-center text-muted bg-light-subtle">
                        Chưa chọn ảnh mới.
                    </div>
                </div>
            `;
        });
    </script>
}
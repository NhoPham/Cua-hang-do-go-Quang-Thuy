@model IEnumerable<Product>

@{
    ViewData["Title"] = "Danh sách sản phẩm";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
        <h1 class="fw-bold mb-1">Danh sách sản phẩm</h1>
        <p class="text-muted mb-0">Chọn sản phẩm phù hợp và thêm ngay vào giỏ hàng.</p>
    </div>

    @if (User.IsInRole("admin"))
    {
        <div class="d-flex gap-2">
            <a asp-action="Create" class="btn btn-dark">Thêm sản phẩm</a>
            <form asp-action="DeleteAll" method="post">
                @Html.AntiForgeryToken()
                <button class="btn btn-outline-danger" type="submit" onclick="return confirm('Xóa toàn bộ sản phẩm?');">Xóa tất cả</button>
            </form>
        </div>
    }
</div>

<form method="get" class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body row g-3 align-items-end">
        <div class="col-md-5">
            <label class="form-label">Từ khóa</label>
            <input type="text" name="searchString" value="@ViewBag.SearchString" class="form-control" placeholder="Nhập tên sản phẩm..." />
        </div>
        <div class="col-md-4">
            <label class="form-label">Danh mục</label>
            <select class="form-select" name="categoryId" asp-items="ViewBag.CategoryId">
                <option value="">Tất cả danh mục</option>
            </select>
        </div>
        <div class="col-md-3 d-grid">
            <button class="btn btn-primary">Tìm kiếm</button>
        </div>
    </div>
</form>

<div class="row g-4">
    @foreach (var item in Model)
    {
        var firstImage = ImageHelper.GetFirstImageOrDefault(item.Images);
        <div class="col-xl-3 col-lg-4 col-md-6">
            <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden">
                <img src="@firstImage" alt="@item.Name" class="card-img-top product-image" data-product-id="@item.Id" style="height: 220px; object-fit: cover;" />
                <div class="card-body d-flex flex-column">
                    <h5 class="fw-semibold">@item.Name</h5>
                    <p class="text-muted small mb-2">Tồn kho: @item.Stock</p>
                    <p class="text-muted flex-grow-1">@(string.IsNullOrWhiteSpace(item.Description) ? "Chưa có mô tả." : item.Description)</p>
                    <div class="fw-bold fs-5 text-danger mb-3">@item.Price.ToString("N0") đ</div>

                    <div class="d-grid gap-2">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-dark">Chi tiết</a>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <form asp-controller="Cart" asp-action="Add" method="post" class="d-grid">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@item.Id" />
                                <input type="hidden" name="returnUrl" value="@($"{Context.Request.Path}{Context.Request.QueryString}")" />
                                <button class="btn btn-primary" type="submit" @(item.Stock <= 0 ? "disabled" : null)>
                                    @(item.Stock > 0 ? "Thêm vào giỏ" : "Hết hàng")
                                </button>
                            </form>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@($"{Context.Request.Path}{Context.Request.QueryString}")" class="btn btn-primary">
                                Đăng nhập để mua
                            </a>
                        }

                        @if (User.IsInRole("admin"))
                        {
                            <div class="d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning w-50">Sửa</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger w-50">Xóa</a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (ViewBag.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @{
                var currentPage = (int)ViewBag.CurrentPage;
                var totalPages = (int)ViewBag.TotalPages;
                var searchString = (string?)ViewBag.SearchString;
                var selectedCategoryId = (int?)ViewBag.SelectedCategoryId;
            }

            <li class="page-item @(currentPage == 1 ? "disabled" : null)">
                <a class="page-link" asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-searchString="@searchString" asp-route-categoryId="@selectedCategoryId">«</a>
            </li>

            @for (var i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : null)">
                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-searchString="@searchString" asp-route-categoryId="@selectedCategoryId">@i</a>
                </li>
            }

            <li class="page-item @(currentPage == totalPages ? "disabled" : null)">
                <a class="page-link" asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-searchString="@searchString" asp-route-categoryId="@selectedCategoryId">»</a>
            </li>
        </ul>
    </nav>
}

@using System.Text.Json

@{
    var imageMap = new Dictionary<string, List<string>>();

    foreach (var p in Model)
    {
        imageMap[p.Id.ToString()] = string.IsNullOrWhiteSpace(p.Images)
            ? new List<string>()
            : p.Images
                .Split(',', StringSplitOptions.RemoveEmptyEntries)
                .Select(x => x.Trim())
                .Where(x => !string.IsNullOrWhiteSpace(x))
                .ToList();
    }

    var imagesJson = JsonSerializer.Serialize(imageMap);
}
<script>
    document.addEventListener("DOMContentLoaded", function () {
        document.querySelectorAll(".product-image").forEach(img => {
            const raw = img.dataset.images;
            if (!raw) return;

            let productImages = [];

            try {
                productImages = JSON.parse(raw);
            } catch {
                return;
            }

            if (productImages && productImages.length > 1) {
                let currentIndex = 0;

                setInterval(() => {
                    currentIndex = (currentIndex + 1) % productImages.length;
                    img.src = productImages[currentIndex];
                }, 3000);
            }
        });
    });
</script>
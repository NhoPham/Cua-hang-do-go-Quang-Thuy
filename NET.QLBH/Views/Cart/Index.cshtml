@model CartViewModel

@{
    ViewData["Title"] = "Giỏ hàng";
}

<div class="wood-page">
    <section class="wood-page-hero mb-4">
        <div class="row g-4 align-items-center position-relative" style="z-index:2;">
            <div class="col-lg-8">
                <div class="wood-page-kicker mb-3">
                    <span>•</span>
                    <span>Giỏ hàng của bạn</span>
                </div>
                <h1 class="wood-page-title">Kiểm tra lại sản phẩm trước khi thanh toán</h1>
                <p class="wood-page-subtitle">
                    Cập nhật số lượng, xóa sản phẩm không cần thiết và kiểm tra tổng tiền ngay trong một giao diện đồng bộ hơn.
                </p>
            </div>
            <div class="col-lg-4">
                <div class="wood-mini-stat-grid">
                    <div class="wood-mini-stat">
                        <div class="wood-mini-stat-label">Số dòng hàng</div>
                        <div class="wood-mini-stat-value">@Model.Items.Count()</div>
                    </div>
                    <div class="wood-mini-stat">
                        <div class="wood-mini-stat-label">Tổng số lượng</div>
                        <div class="wood-mini-stat-value">@Model.Items.Sum(x => x.Quantity)</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @if (!Model.Items.Any())
    {
        <div class="surface-card wood-empty">
            <div class="wood-empty-title">Giỏ hàng của bạn đang trống</div>
            <p class="wood-empty-text">Hãy quay lại trang sản phẩm để thêm món hàng bạn muốn mua vào giỏ.</p>
            <a asp-controller="Product" asp-action="Index" class="btn wood-btn-primary">Xem sản phẩm</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="d-grid gap-3">
                    @foreach (var item in Model.Items)
                    {
                        <div class="surface-card">
                            <div class="surface-card-body">
                                <div class="row g-3 align-items-center">
                                    <div class="col-md-auto">
                                        <img src="@item.ProductImage"
                                             alt="@item.ProductName"
                                             class="wood-thumb" />
                                    </div>

                                    <div class="col">
                                        <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
                                            <div>
                                                <h3 class="h5 fw-bold mb-1">@item.ProductName</h3>
                                                <div class="text-wood-muted mb-2">Tồn kho tối đa: @item.MaxStock</div>
                                                <div class="fw-semibold text-wood-brown">@item.UnitPrice.ToString("N0") đ</div>
                                            </div>

                                            <div class="text-lg-end">
                                                <div class="text-wood-muted small">Thành tiền</div>
                                                <div class="h5 fw-bold mb-0">@item.SubTotal.ToString("N0") đ</div>
                                            </div>
                                        </div>

                                        <div class="wood-divider"></div>

                                        <div class="row g-3 align-items-end">
                                            <div class="col-md-8">
                                                <form asp-action="UpdateQuantity" method="post" class="row g-2 align-items-end">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@item.CartItemId" />

                                                    <div class="col-sm-5">
                                                        <label class="wood-label">Số lượng</label>
                                                        <input type="number"
                                                               name="quantity"
                                                               value="@item.Quantity"
                                                               min="1"
                                                               max="@Math.Max(item.MaxStock, 1)"
                                                               class="form-control wood-input" />
                                                    </div>

                                                    <div class="col-sm-7 d-grid d-sm-flex gap-2">
                                                        <button class="btn wood-btn-primary flex-fill" type="submit">Cập nhật</button>
                                                        <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId" class="btn wood-btn-outline flex-fill">Xem sản phẩm</a>
                                                    </div>
                                                </form>
                                            </div>

                                            <div class="col-md-4">
                                                <form asp-action="Remove" method="post" class="d-grid">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@item.CartItemId" />
                                                    <button class="btn btn-outline-danger rounded-4 py-3" type="submit">Xóa khỏi giỏ</button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    <form asp-action="Clear" method="post" class="d-grid d-md-flex justify-content-start">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-outline-danger rounded-4 px-4 py-3" type="submit">Xóa toàn bộ giỏ hàng</button>
                    </form>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="wood-sidebar-sticky">
                    <div class="surface-card-dark">
                        <div class="surface-card-body-lg">
                            <h3 class="text-white fw-bold mb-3">Tóm tắt đơn hàng</h3>

                            <div class="wood-summary-row">
                                <span class="text-white-50">Số sản phẩm</span>
                                <strong>@Model.Items.Sum(x => x.Quantity)</strong>
                            </div>

                            <div class="wood-summary-row">
                                <span class="text-white-50">Tạm tính</span>
                                <strong>@Model.TotalAmount.ToString("N0") đ</strong>
                            </div>

                            <div class="wood-summary-row">
                                <span class="text-white-50">Vận chuyển</span>
                                <strong>Xác nhận ở checkout</strong>
                            </div>

                            <div class="mt-4 mb-3">
                                <div class="small text-white-50 mb-1">Tổng dự kiến</div>
                                <div class="wood-summary-total text-white">@Model.TotalAmount.ToString("N0") đ</div>
                            </div>

                            <div class="d-grid gap-2">
                                <a asp-controller="Order" asp-action="Checkout" class="btn wood-btn-primary">Tiến hành thanh toán</a>
                                <a asp-controller="Product" asp-action="Index" class="btn wood-btn-outline">Mua thêm</a>
                            </div>

                            <div class="mt-3 small text-white-50">
                                Giá vận chuyển và xác nhận thanh toán sẽ được hiển thị ở bước đặt đơn.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

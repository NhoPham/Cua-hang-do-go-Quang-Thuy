@using QLBH.ViewModels
@model OrderHistoryIndexViewModel

@{
    ViewData["Title"] = "Đơn của tôi";
    var latestDate = Model.Items.Any()
        ? Model.Items.OrderByDescending(x => x.CreatedAt).First().CreatedAt.ToLocalTime().ToString("dd/MM")
        : "--";
}

<div class="wood-page">
    <section class="wood-page-hero mb-4">
        <div class="row g-4 align-items-center position-relative" style="z-index:2;">
            <div class="col-lg-8">
                <div class="wood-page-kicker mb-3">
                    <span>•</span>
                    <span>Lịch sử mua hàng và đặt riêng</span>
                </div>
                <h1 class="wood-page-title">Đơn của tôi</h1>
                <p class="wood-page-subtitle">
                    Theo dõi cả đơn mua hàng thông thường và yêu cầu đặt hàng theo yêu cầu trong cùng một giao diện.
                </p>
            </div>

            <div class="col-lg-4">
                <div class="wood-mini-stat-grid">
                    <div class="wood-mini-stat">
                        <div class="wood-mini-stat-label">Tổng mục</div>
                        <div class="wood-mini-stat-value">@Model.Items.Count</div>
                    </div>
                    <div class="wood-mini-stat">
                        <div class="wood-mini-stat-label">Mới nhất</div>
                        <div class="wood-mini-stat-value">@latestDate</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @if (!Model.Items.Any())
    {
        <div class="surface-card wood-empty">
            <div class="wood-empty-title">Bạn chưa có đơn hàng hoặc yêu cầu đặt riêng nào</div>
            <p class="wood-empty-text">Bắt đầu mua sắm hoặc gửi yêu cầu đặt riêng để theo dõi tiến độ tại đây.</p>
            <div class="d-flex gap-2 flex-wrap">
                <a asp-controller="Product" asp-action="Index" class="btn wood-btn-primary">Mua sản phẩm</a>
                <a asp-controller="CustomOrder" asp-action="Create" class="btn btn-outline-dark">Đặt theo yêu cầu</a>
            </div>
        </div>
    }
    else
    {
        <div class="d-grid gap-3">
            @foreach (var item in Model.Items.OrderByDescending(x => x.CreatedAt))
            {
                <div class="wood-order-card">
                    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
                        <div>
                            <div class="text-wood-muted small mb-1">@(item.IsCustomOrder ? "Mã yêu cầu" : "Mã đơn")</div>
                            <div class="h5 fw-bold mb-1">@item.Code</div>
                            <div class="text-wood-muted">Tạo lúc @item.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                            <div class="mt-2 fw-semibold">@item.Title</div>
                            <div class="text-wood-muted">@item.Description</div>
                        </div>

                        <div class="wood-order-meta d-flex flex-wrap align-items-start justify-content-lg-end gap-2">
                            <span class="badge @(item.IsCustomOrder ? "bg-dark" : "bg-light text-dark border")">
                                @(item.IsCustomOrder ? "Đặt riêng" : "Mua hàng")
                            </span>

                            @if (!string.IsNullOrWhiteSpace(item.PaymentStatusLabel))
                            {
                                <span class="badge @item.PaymentBadgeClass">@item.PaymentStatusLabel</span>
                            }

                            <span class="badge @item.StatusBadgeClass">@item.StatusLabel</span>
                        </div>
                    </div>

                    <div class="wood-divider"></div>

                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                        <div class="text-wood-muted small">
                            @if (item.TotalAmount.HasValue)
                            {
                                <span>Giá trị tham chiếu: <strong>@item.TotalAmount.Value.ToString("N0") VND</strong></span>
                            }
                            else
                            {
                                <span>Chưa có báo giá / tổng tiền</span>
                            }
                        </div>

                        @if (item.IsCustomOrder)
                        {
                            <a asp-controller="CustomOrder" asp-action="MyDetails" asp-route-id="@item.Id" class="btn wood-btn-primary">
                                Xem chi tiết yêu cầu
                            </a>
                        }
                        else
                        {
                            <a asp-controller="Order" asp-action="Details" asp-route-id="@item.Id" class="btn wood-btn-primary">
                                Xem chi tiết đơn hàng
                            </a>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

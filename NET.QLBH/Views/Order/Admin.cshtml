@model IEnumerable<Order>

@{
    ViewData["Title"] = "Quản lý đơn hàng";
}

<div class="wood-page">
    <section class="wood-page-hero mb-4">
        <div class="row g-4 align-items-center position-relative" style="z-index:2;">
            <div class="col-lg-8">
                <div class="wood-page-kicker mb-3">
                    <span>•</span>
                    <span>Khu vực quản trị</span>
                </div>
                <h1 class="wood-page-title">Quản lý đơn hàng</h1>
                <p class="wood-page-subtitle">Admin có thể xem danh sách đơn, trạng thái xử lý, thanh toán và mở nhanh chi tiết từng đơn.</p>
            </div>
            <div class="col-lg-4">
                <div class="wood-mini-stat-grid">
                    <div class="wood-mini-stat">
                        <div class="wood-mini-stat-label">Tổng đơn</div>
                        <div class="wood-mini-stat-value">@Model.Count()</div>
                    </div>
                    <div class="wood-mini-stat">
                        <div class="wood-mini-stat-label">Hiển thị</div>
                        <div class="wood-mini-stat-value">Dạng bảng</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="surface-card">
        <div class="surface-card-body p-0">
            <div class="wood-table-wrap table-responsive">
                <table class="table wood-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">Mã đơn</th>
                            <th>Khách hàng</th>
                            <th>Ngày tạo</th>
                            <th>Trạng thái</th>
                            <th>Thanh toán</th>
                            <th class="text-end">Tổng tiền</th>
                            <th class="text-end pe-4">Chi tiết</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            @foreach (var order in Model.OrderByDescending(x => x.CreatedAt))
                            {
                                <tr>
                                    <td class="ps-4 fw-semibold">@order.OrderCode</td>
                                    <td>
                                        <div class="fw-semibold">@order.ReceiverName</div>
                                        <div class="text-wood-muted small">@order.Email</div>
                                    </td>
                                    <td>@order.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        <span class="badge @OrderUiHelper.OrderStatusBadgeClass(order.OrderStatus)">
                                            @OrderUiHelper.OrderStatusLabel(order.OrderStatus)
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge @OrderUiHelper.PaymentStatusBadgeClass(order.PaymentStatus)">
                                            @OrderUiHelper.PaymentStatusLabel(order.PaymentStatus)
                                        </span>
                                    </td>
                                    <td class="text-end fw-semibold">@order.TotalAmount.ToString("N0") đ</td>
                                    <td class="text-end pe-4">
                                        <a asp-action="Details" asp-route-id="@order.Id" class="btn wood-btn-outline btn-sm px-3 py-2">Xem</a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-wood-muted">Chưa có đơn hàng nào để hiển thị.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

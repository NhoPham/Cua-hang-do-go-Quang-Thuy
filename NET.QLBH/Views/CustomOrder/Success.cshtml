@{
    ViewData["Title"] = "Đã gửi yêu cầu";
}

<div class="container py-5">
    <div class="mx-auto" style="max-width:720px;">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-5 text-center">
                <h1 class="h3 mb-3">Gửi yêu cầu thành công</h1>
                <p class="text-muted mb-2">Cửa hàng đã nhận được yêu cầu đặt hàng theo yêu cầu của bạn.</p>
                <p class="mb-4">Mã yêu cầu: <strong>@ViewBag.RequestCode</strong></p>
                <div class="d-flex justify-content-center gap-2 flex-wrap">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-dark">Về trang chủ</a>
                    <a asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary">Xem sản phẩm</a>
                </div>
            </div>
        </div>
    </div>
</div>

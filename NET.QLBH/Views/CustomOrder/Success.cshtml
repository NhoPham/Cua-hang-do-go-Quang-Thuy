@{
    ViewData["Title"] = "Gửi yêu cầu thành công";
    var code = ViewBag.RequestCode as string;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4 p-lg-5 text-center">
                    <div class="mb-3" style="font-size:48px;">✅</div>
                    <h1 class="h3 fw-bold mb-3">Gửi yêu cầu thành công</h1>
                    <p class="text-muted mb-3">
                        Cửa hàng đã nhận được yêu cầu đặt hàng theo yêu cầu của bạn.
                    </p>

                    <div class="alert alert-success rounded-4">
                        Mã yêu cầu của bạn: <strong>@code</strong>
                    </div>

                    <p class="text-muted">
                        Vui lòng lưu lại mã này để tra cứu tiến độ xử lý sau.
                    </p>

                    <div class="d-flex justify-content-center flex-wrap gap-2 mt-4">
                        <a asp-controller="CustomOrder"
                           asp-action="Lookup"
                           class="btn btn-dark rounded-pill px-4">
                            Xem yêu cầu của tôi
                        </a>

                        <a asp-controller="Home"
                           asp-action="Index"
                           class="btn btn-outline-secondary rounded-pill px-4">
                            Về trang chủ
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
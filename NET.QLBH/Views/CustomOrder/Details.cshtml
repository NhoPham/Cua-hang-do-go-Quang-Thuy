@using QLBH.Utils
@model QLBH.Models.CustomOrderRequest

@{
    ViewData["Title"] = "Chi tiết yêu cầu";
    var images = CustomOrderUiHelper.ParseReferenceImageUrls(Model.ReferenceImageUrls);
    var returnTo = (ViewBag.ReturnTo as string ?? string.Empty).Trim().ToLowerInvariant();
    var returnStatus = ViewBag.ReturnStatus as string;
    var returnKeyword = ViewBag.ReturnKeyword as string;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-xl-10">
            <div class="card shadow-sm border-0 rounded-4 mb-4 overflow-hidden">
                <div class="card-body p-4 p-lg-5">
                    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
                        <div>
                            <div class="text-muted small mb-2">Mã yêu cầu</div>
                            <h1 class="h3 fw-bold mb-1">@Model.RequestCode</h1>
                            <div class="text-muted">@Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                        </div>
                        <div class="d-flex gap-2 flex-wrap">
                            <span class="badge bg-dark rounded-pill px-3 py-2">Đặt riêng</span>
                            <span class="badge @CustomOrderUiHelper.StatusBadgeClass(Model.Status) rounded-pill px-3 py-2">@CustomOrderUiHelper.StatusLabel(Model.Status)</span>
                        </div>
                    </div>

                    <div class="row g-4">
                        <div class="col-lg-6">
                            <div class="border rounded-4 p-4 h-100 bg-white">
                                <h2 class="h5 fw-bold mb-3">Thông tin khách hàng</h2>
                                <div class="small text-muted mb-1">Họ tên</div>
                                <div class="mb-3">@Model.CustomerName</div>
                                <div class="small text-muted mb-1">Email</div>
                                <div class="mb-3">@Model.Email</div>
                                <div class="small text-muted mb-1">Số điện thoại</div>
                                <div>@Model.Phone</div>
                            </div>
                        </div>

                        <div class="col-lg-6">
                            <div class="border rounded-4 p-4 h-100 bg-white">
                                <h2 class="h5 fw-bold mb-3">Thông tin yêu cầu</h2>
                                <div class="small text-muted mb-1">Sản phẩm mong muốn</div>
                                <div class="mb-2">@Model.RequestedProductName</div>
                                <div class="small text-muted mb-1">Loại gỗ</div>
                                <div class="mb-2">@(string.IsNullOrWhiteSpace(Model.WoodType) ? "Chưa cung cấp" : Model.WoodType)</div>
                                <div class="small text-muted mb-1">Kích thước</div>
                                <div class="mb-2">@(string.IsNullOrWhiteSpace(Model.Dimensions) ? "Chưa cung cấp" : Model.Dimensions)</div>
                                <div class="small text-muted mb-1">Số lượng</div>
                                <div class="mb-2">@Model.Quantity</div>
                                <div class="small text-muted mb-1">Ngân sách dự kiến</div>
                                <div class="mb-2">@(Model.EstimatedBudget.HasValue ? $"{Model.EstimatedBudget.Value:N0} VND" : "Chưa cung cấp")</div>
                                <div class="small text-muted mb-1">Ngày mong muốn nhận</div>
                                <div>@(Model.DesiredDeliveryDate.HasValue ? Model.DesiredDeliveryDate.Value.ToString("dd/MM/yyyy") : "Chưa cung cấp")</div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="border rounded-4 p-4 bg-white">
                                <h2 class="h5 fw-bold mb-3">Mô tả chi tiết</h2>
                                <div class="text-muted" style="white-space:pre-line;">@Model.Description</div>
                            </div>
                        </div>

                        @if (Model.Product != null)
                        {
                            <div class="col-12">
                                <div class="border rounded-4 p-4 bg-light">
                                    <h2 class="h5 fw-bold mb-2">Sản phẩm tham chiếu trong hệ thống</h2>
                                    <div class="d-flex flex-wrap gap-3 align-items-center justify-content-between">
                                        <div>
                                            <div class="fw-semibold">@Model.Product.Name</div>
                                            <div class="text-muted small">Giá tham khảo: @Model.Product.Price.ToString("N0") VND</div>
                                        </div>
                                        <a asp-controller="Product" asp-action="Details" asp-route-id="@Model.Product.Id" class="btn btn-outline-dark">Xem sản phẩm</a>
                                    </div>
                                </div>
                            </div>
                        }

                        <div class="col-12">
                            <div class="border rounded-4 p-4 bg-white">
                                <h2 class="h5 fw-bold mb-3">Ảnh tham khảo</h2>
                                @if (images.Any())
                                {
                                    <div class="row g-3">
                                        @foreach (var image in images)
                                        {
                                            <div class="col-sm-6 col-lg-4">
                                                <a href="@image" target="_blank" class="text-decoration-none">
                                                    <img src="@image" class="img-fluid rounded-4 border" alt="Ảnh tham khảo" style="width:100%;height:220px;object-fit:cover;" />
                                                </a>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="text-muted">Chưa có ảnh tham khảo.</div>
                                }
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="border rounded-4 p-4 bg-white">
                                <h2 class="h5 fw-bold mb-3">Tiến độ xử lý</h2>
                                <div class="mb-2">Trạng thái hiện tại: <strong>@CustomOrderUiHelper.StatusLabel(Model.Status)</strong></div>
                                <div class="text-muted">Thông tin trạng thái và ghi chú từ cửa hàng sẽ được cập nhật tại đây.</div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="alert alert-info border-0 rounded-4 mb-0">
                                <div class="fw-semibold mb-1">Ghi chú từ cửa hàng</div>
                                <div style="white-space:pre-line;">@(string.IsNullOrWhiteSpace(Model.AdminNote) ? "Chưa có ghi chú từ cửa hàng." : Model.AdminNote)</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 flex-wrap">
                @if (returnTo == "admin")
                {
                    <a asp-action="Admin"
                       asp-route-status="@returnStatus"
                       asp-route-keyword="@returnKeyword"
                       class="btn btn-dark rounded-pill px-4">
                        Quay lại quản lý yêu cầu đặt hàng
                    </a>
                }
                else if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="Order" asp-action="Index" class="btn btn-dark rounded-pill px-4">Về Đơn của tôi</a>
                }
                else
                {
                    <a asp-controller="CustomOrder" asp-action="Lookup" class="btn btn-dark rounded-pill px-4">Tra cứu yêu cầu</a>
                }

                <a asp-controller="CustomOrder" asp-action="Lookup" class="btn btn-outline-secondary rounded-pill px-4">Tra cứu bằng mã</a>
            </div>
        </div>
    </div>
</div>

@model QLBH.ViewModels.CustomOrderRequestViewModel
@{
    ViewData["Title"] = "Đặt hàng theo yêu cầu";
}

<div class="container py-5">
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4 p-lg-5">
                    <h1 class="h3 mb-2">Đặt hàng theo yêu cầu</h1>
                    <p class="text-muted mb-4">
                        Gửi mô tả sản phẩm bạn muốn làm riêng. Cửa hàng sẽ liên hệ tư vấn và báo giá.
                    </p>

                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <input asp-for="ProductId" type="hidden" />
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="CustomerName" class="form-label"></label>
                                <input asp-for="CustomerName" class="form-control" />
                                <span asp-validation-for="CustomerName" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Phone" class="form-label"></label>
                                <input asp-for="Phone" class="form-control" />
                                <span asp-validation-for="Phone" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label"></label>
                                <input asp-for="Email" class="form-control" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="RequestedProductName" class="form-label"></label>
                                <input asp-for="RequestedProductName" class="form-control" />
                                <span asp-validation-for="RequestedProductName" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="WoodType" class="form-label"></label>
                                <input asp-for="WoodType" class="form-control" placeholder="Ví dụ: gỗ sồi, óc chó..." />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Dimensions" class="form-label"></label>
                                <input asp-for="Dimensions" class="form-control" placeholder="Ví dụ: 160x80x75 cm" />
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Quantity" class="form-label"></label>
                                <input asp-for="Quantity" class="form-control" />
                                <span asp-validation-for="Quantity" class="text-danger"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="EstimatedBudget" class="form-label"></label>
                                <input asp-for="EstimatedBudget" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label asp-for="DesiredDeliveryDate" class="form-label"></label>
                                <input asp-for="DesiredDeliveryDate" type="date" class="form-control" />
                            </div>
                            <div class="col-12">
                                <label asp-for="ReferenceImageUrls" class="form-label"></label>
                                <textarea asp-for="ReferenceImageUrls" class="form-control" rows="2"></textarea>
                            </div>
                            <div class="col-12">
                                <label asp-for="Description" class="form-label"></label>
                                <textarea asp-for="Description" class="form-control" rows="6" placeholder="Mô tả chi tiết kiểu dáng, màu sắc, công năng, yêu cầu đặc biệt..."></textarea>
                                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-dark px-4">Gửi yêu cầu</button>
                            <a asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary">Quay lại sản phẩm</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <h2 class="h5 mb-3">Mẫu tham chiếu</h2>
                    @if (!string.IsNullOrWhiteSpace(Model.ProductName))
                    {
                        <img src="@Model.ProductImage" alt="@Model.ProductName" class="img-fluid rounded-4 mb-3" />
                        <div class="fw-semibold">@Model.ProductName</div>
                        <p class="text-muted small mb-0">Bạn đang gửi yêu cầu dựa trên sản phẩm tham chiếu này.</p>
                    }
                    else
                    {
                        <p class="text-muted mb-0">Bạn có thể gửi yêu cầu hoàn toàn mới, không cần chọn sẵn một sản phẩm.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}

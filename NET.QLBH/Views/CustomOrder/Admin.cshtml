@using QLBH.Utils
@model IEnumerable<QLBH.Models.CustomOrderRequest>

@{
    ViewData["Title"] = "Quản lý yêu cầu đặt hàng";
    var keyword = ViewBag.Keyword as string;
    var status = ViewBag.Status as string;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">Quản lý yêu cầu đặt hàng</h1>
            <p class="text-muted mb-0">Theo dõi yêu cầu đóng mới, chỉnh sửa, báo giá và tiến độ thực hiện.</p>
        </div>
    </div>

    <form method="get" class="row g-3 mb-4">
        <div class="col-md-5">
            <input name="keyword" value="@keyword" class="form-control" placeholder="Tìm theo mã, tên khách, email, sản phẩm..." />
        </div>
        <div class="col-md-3">
            <select name="status" class="form-select">
                <option value="">Tất cả trạng thái</option>
                @foreach (var item in CustomOrderStatuses.All)
                {
                    <option value="@item" selected="@(status == item)">@CustomOrderUiHelper.StatusLabel(item)</option>
                }
            </select>
        </div>
        <div class="col-md-4 d-flex gap-2">
            <button class="btn btn-dark" type="submit">Lọc</button>
            <a asp-action="Admin" class="btn btn-outline-secondary">Làm mới</a>
        </div>
    </form>

    <div class="d-grid gap-3">
        @foreach (var request in Model)
        {
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <div class="d-flex flex-column flex-xl-row justify-content-between gap-4">
                        <div class="flex-grow-1">
                            <div class="d-flex flex-wrap gap-2 align-items-center mb-2">
                                <h2 class="h5 mb-0">@request.RequestCode</h2>
                                <span class="badge @CustomOrderUiHelper.StatusBadgeClass(request.Status)">@CustomOrderUiHelper.StatusLabel(request.Status)</span>
                            </div>

                            <div class="text-muted small mb-2">@request.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                            <div><strong>Khách:</strong> @request.CustomerName - @request.Email - @request.Phone</div>
                            <div><strong>Sản phẩm:</strong> @request.RequestedProductName</div>
                            <div><strong>Số lượng:</strong> @request.Quantity</div>
                            @if (request.EstimatedBudget.HasValue)
                            {
                                <div><strong>Ngân sách:</strong> @request.EstimatedBudget.Value.ToString("N0") VND</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(request.AdminNote))
                            {
                                <div class="mt-2 small text-muted"><strong>Ghi chú hiện tại:</strong> @request.AdminNote</div>
                            }
                        </div>

                        <div class="flex-shrink-0" style="min-width:320px;">
                            <form asp-action="UpdateStatus" method="post" class="row g-2">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@request.Id" />
                                <div class="col-12">
                                    <select name="status" class="form-select">
                                        @foreach (var item in CustomOrderStatuses.All)
                                        {
                                            <option value="@item" selected="@(request.Status == item)">@CustomOrderUiHelper.StatusLabel(item)</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-12">
                                    <textarea name="adminNote" class="form-control" rows="3" placeholder="Ghi chú cho khách hoặc nội bộ">@request.AdminNote</textarea>
                                </div>
                                <div class="col-12 d-flex gap-2 flex-wrap">
                                    <button type="submit" class="btn btn-dark">Cập nhật</button>
                                    <a asp-action="MyDetails" asp-route-id="@request.Id" class="btn btn-outline-secondary">Xem chi tiết</a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

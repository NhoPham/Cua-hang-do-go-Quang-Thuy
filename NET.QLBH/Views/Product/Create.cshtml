@model QLBH.Models.Product

@{
    ViewData["Title"] = "Tạo sản phẩm mới";

    @* CHANGED: dùng để giữ lại dữ liệu danh mục mới khi submit lỗi *@
    var newCategoryName = ViewBag.NewCategoryName as string ?? "";
    var newCategoryDescription = ViewBag.NewCategoryDescription as string ?? "";
    var showNewCategoryPanel = !string.IsNullOrWhiteSpace(newCategoryName) || !string.IsNullOrWhiteSpace(newCategoryDescription);
}

<style>
    .product-editor-page {
        --wood-950: #241913;
        --wood-900: #2f2219;
        --wood-800: #4c392b;
        --wood-700: #6f533d;
        --wood-500: #b89268;
        --wood-300: #eadac8;
        --wood-200: #f6ede5;
        --wood-100: #fbf7f2;
        --wood-border: #e7d9ca;
        --wood-text: #4f3d2f;
        --wood-muted: #8f7b67;
    }

    .product-editor-page .editor-hero {
        position: relative;
        overflow: hidden;
        border-radius: 30px;
        padding: 1.8rem;
        background: linear-gradient(135deg, rgba(36,25,19,.98), rgba(79,59,43,.92));
        color: #fff;
        box-shadow: 0 22px 54px rgba(36,25,19,.16);
    }

    .product-editor-page .editor-hero::after {
        content: "";
        position: absolute;
        right: -30px;
        top: -36px;
        width: 150px;
        height: 150px;
        border-radius: 50%;
        background: rgba(255,255,255,.06);
    }

    .product-editor-page .editor-kicker,
    .product-editor-page .editor-chip {
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        padding: .55rem .95rem;
        border-radius: 999px;
        font-weight: 600;
        font-size: .92rem;
    }

    .product-editor-page .editor-kicker {
        background: rgba(255,255,255,.08);
        border: 1px solid rgba(255,255,255,.08);
        color: #f6e7d6;
    }

    .product-editor-page .editor-title {
        font-size: clamp(2rem, 4vw, 3rem);
        line-height: 1.1;
        font-weight: 800;
        letter-spacing: -.03em;
    }

    .product-editor-page .editor-desc {
        color: rgba(255,255,255,.76);
        line-height: 1.8;
        margin-bottom: 0;
    }

    .product-editor-page .editor-panel,
    .product-editor-page .side-panel,
    .product-editor-page .preview-box {
        border-radius: 26px;
        border: 1px solid var(--wood-border);
        background: #fff;
        box-shadow: 0 14px 34px rgba(36,25,19,.07);
    }

    .product-editor-page .editor-panel,
    .product-editor-page .side-panel {
        padding: 1.5rem;
    }

    .product-editor-page .side-panel {
        background: linear-gradient(135deg, #fff, var(--wood-100));
        height: 100%;
    }

    .product-editor-page .editor-chip {
        background: var(--wood-200);
        color: var(--wood-text);
    }

    .product-editor-page .panel-title,
    .product-editor-page .form-label,
    .product-editor-page .metric-title {
        color: var(--wood-text);
    }

    .product-editor-page .panel-title {
        font-size: 1.2rem;
        font-weight: 800;
        margin-bottom: .35rem;
    }

    .product-editor-page .panel-text,
    .product-editor-page .metric-text,
    .product-editor-page .form-text,
    .product-editor-page .hint-list li {
        color: var(--wood-muted);
        line-height: 1.75;
    }

    .product-editor-page .metric-card {
        border-radius: 20px;
        border: 1px solid var(--wood-border);
        background: rgba(246,237,229,.55);
        padding: 1rem;
        height: 100%;
    }

    .product-editor-page .metric-title {
        font-size: .88rem;
        font-weight: 700;
        margin-bottom: .35rem;
    }

    .product-editor-page .metric-value {
        color: var(--wood-900);
        font-size: 1.1rem;
        font-weight: 800;
    }

    .product-editor-page .form-label {
        font-weight: 700;
        margin-bottom: .55rem;
    }

    .product-editor-page .form-control,
    .product-editor-page .form-select {
        min-height: 52px;
        border-radius: 16px;
        border: 1px solid #d6c6b6;
        background: #fffefc;
        box-shadow: none;
    }

    .product-editor-page textarea.form-control {
        min-height: 140px;
    }

    .product-editor-page .form-control:focus,
    .product-editor-page .form-select:focus {
        border-color: var(--wood-500);
        box-shadow: 0 0 0 .15rem rgba(184,146,104,.18);
    }

    .product-editor-page .upload-box {
        border: 1.5px dashed #d6c6b6;
        border-radius: 22px;
        padding: 1.1rem;
        background: linear-gradient(135deg, var(--wood-100), #fff);
    }

    .product-editor-page .preview-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
        gap: 1rem;
    }

    .product-editor-page .preview-box {
        overflow: hidden;
    }

    .product-editor-page .preview-box img {
        width: 100%;
        height: 170px;
        object-fit: cover;
        display: block;
    }

    .product-editor-page .preview-caption {
        padding: .7rem .8rem;
        font-size: .9rem;
        color: var(--wood-muted);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .product-editor-page .action-row .btn {
        min-width: 180px;
        border-radius: 16px;
        padding: .9rem 1.2rem;
        font-weight: 700;
    }

    @* CHANGED: style cho box thêm danh mục mới *@
    .product-editor-page .new-category-card {
        border: 1px solid var(--wood-border);
        border-radius: 22px;
        padding: 1rem;
        background: linear-gradient(135deg, #fff, var(--wood-100));
        box-shadow: inset 0 1px 0 rgba(255,255,255,.7);
    }

    .product-editor-page .new-category-head {
        display: flex;
        justify-content: space-between;
        align-items: start;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .product-editor-page .new-category-title {
        color: var(--wood-text);
        font-size: 1rem;
        font-weight: 800;
        margin-bottom: .15rem;
    }

    .product-editor-page .new-category-note {
        font-size: .92rem;
        color: var(--wood-muted);
        line-height: 1.7;
        margin-bottom: 0;
    }

    .product-editor-page .toggle-category-btn {
        border-radius: 14px;
        font-weight: 700;
        padding: .75rem 1rem;
    }

    .product-editor-page .soft-badge {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        padding: .45rem .8rem;
        border-radius: 999px;
        background: var(--wood-200);
        color: var(--wood-text);
        font-size: .88rem;
        font-weight: 700;
    }

    @@media (max-width: 767.98px) {
        .product-editor-page .editor-hero,
        .product-editor-page .editor-panel,
        .product-editor-page .side-panel {
            padding: 1.2rem;
        }

        .product-editor-page .action-row .btn {
            width: 100%;
        }

        .product-editor-page .new-category-head {
            flex-direction: column;
            align-items: stretch;
        }
    }
</style>

<div class="product-editor-page py-4">
    <section class="editor-hero mb-4">
        <div class="row align-items-center g-4 position-relative">
            <div class="col-lg-8">
                <div class="editor-kicker mb-3">
                    <span>•</span>
                    <span>Quản trị sản phẩm</span>
                </div>
                <h1 class="editor-title mb-3">Tạo sản phẩm mới</h1>
                <p class="editor-desc">
                    Đồng bộ giao diện thêm sản phẩm với toàn bộ hệ thống: rõ ràng, ấm tông gỗ,
                    dễ nhập liệu và xem trước hình ảnh trước khi lưu.
                </p>
            </div>
            <div class="col-lg-4">
                <div class="d-flex flex-wrap gap-2 justify-content-lg-end">
                    <span class="editor-chip">Ảnh nhiều file</span>
                    <span class="editor-chip">Danh mục rõ ràng</span>
                    <span class="editor-chip">Preview trực tiếp</span>
                </div>
            </div>
        </div>
    </section>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="side-panel">
                <h5 class="panel-title">Gợi ý trước khi tạo</h5>
                <p class="panel-text mb-4">
                    Điền đủ tên, mô tả, giá, tồn kho và danh mục để sản phẩm hiển thị đẹp hơn ở cả trang khách hàng lẫn admin.
                </p>

                <div class="row g-3 mb-4">
                    <div class="col-sm-6 col-lg-12">
                        <div class="metric-card">
                            <div class="metric-title">Kiểu trình bày</div>
                            <div class="metric-value">Đồng bộ toàn shop</div>
                            <div class="metric-text mt-1">Card, form và nút bấm cùng một ngôn ngữ thiết kế.</div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-lg-12">
                        <div class="metric-card">
                            <div class="metric-title">Hình ảnh</div>
                            <div class="metric-value">Nhiều ảnh / sản phẩm</div>
                            <div class="metric-text mt-1">Hỗ trợ tải một hoặc nhiều ảnh cùng lúc.</div>
                        </div>
                    </div>
                </div>

                <div class="metric-card">
                    <div class="metric-title mb-2">Checklist nhanh</div>
                    <ul class="hint-list mb-0 ps-3">
                        <li>Tên sản phẩm nên ngắn gọn và dễ tìm kiếm.</li>
                        <li>Mô tả tập trung vào chất liệu, công năng, kích thước.</li>
                        <li>Nên chọn ảnh sáng, rõ và đúng tỷ lệ.</li>
                        <li>Đặt giá và số lượng đúng trước khi lưu.</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="editor-panel">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
                    <div>
                        <h4 class="panel-title mb-1">Thông tin sản phẩm</h4>
                        <p class="panel-text mb-0">Nhập dữ liệu theo biểu mẫu bên dưới để thêm sản phẩm vào hệ thống.</p>
                    </div>
                    <a asp-action="Index" class="btn btn-outline-secondary rounded-4 px-4">Quay lại danh sách</a>
                </div>

                <form asp-action="Create" enctype="multipart/form-data" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-4"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Tên sản phẩm</label>
                        <input asp-for="Name" class="form-control" placeholder="Ví dụ: Bàn ăn gỗ sồi 6 ghế" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Mô tả</label>
                        <textarea asp-for="Description" class="form-control" placeholder="Mô tả chất liệu, công năng, phong cách sản phẩm..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Price" class="form-label">Giá bán</label>
                            <input asp-for="Price" class="form-control" placeholder="Nhập giá sản phẩm" />
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Stock" class="form-label">Số lượng tồn kho</label>
                            <input asp-for="Stock" class="form-control" placeholder="Nhập số lượng tồn kho" />
                            <span asp-validation-for="Stock" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mt-3 mb-3">
                        <label asp-for="CategoryId" class="form-label">Danh mục</label>
                        <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId">
                            <option value="">-- Chọn danh mục --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>

                        @* CHANGED: nút mở panel thêm danh mục mới *@
                        <div class="d-flex flex-wrap align-items-center gap-2 mt-3">
                            <button type="button" id="toggleNewCategoryBtn" class="btn btn-outline-dark toggle-category-btn">
                                + Thêm danh mục mới
                            </button>
                            <span class="soft-badge">Không có trong danh sách thì tạo ngay</span>
                        </div>
                    </div>

                    @* CHANGED: panel thêm danh mục mới *@
                    <div id="newCategoryPanel" class="new-category-card mb-3" style="display:@(showNewCategoryPanel ? "block" : "none");">
                        <div class="new-category-head">
                            <div>
                                <div class="new-category-title">Tạo danh mục mới ngay tại form</div>
                                <p class="new-category-note">
                                    Khi bạn nhập tên danh mục mới, hệ thống sẽ ưu tiên tạo hoặc dùng danh mục đó thay cho ô chọn bên trên.
                                </p>
                            </div>
                            <span class="soft-badge">Tạo nhanh</span>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label" for="NewCategoryName">Tên danh mục mới</label>
                                <input id="NewCategoryName"
                                       name="NewCategoryName"
                                       value="@newCategoryName"
                                       class="form-control"
                                       placeholder="Ví dụ: Sofa gỗ, Đèn gỗ..." />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="NewCategoryDescription">Mô tả danh mục</label>
                                <input id="NewCategoryDescription"
                                       name="NewCategoryDescription"
                                       value="@newCategoryDescription"
                                       class="form-control"
                                       placeholder="Mô tả ngắn cho danh mục mới" />
                            </div>
                        </div>

                        <div class="form-text mt-2">
                            Mẹo: nếu đã nhập danh mục mới thì không cần quan tâm dropdown phía trên nữa.
                        </div>
                    </div>

                    <div class="upload-box mb-3">
                        <label for="Images" class="form-label">Hình ảnh sản phẩm</label>
                        <input type="file" id="Images" name="Images" class="form-control" multiple accept="image/*" />
                        <div class="form-text mt-2">
                            Bạn có thể chọn một hoặc nhiều ảnh. Hệ thống sẽ lưu toàn bộ ảnh đã tải lên.
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="fw-bold mb-0" style="color: var(--wood-text);">Xem trước hình ảnh</h6>
                        <span id="previewCount" class="badge rounded-pill text-bg-dark">0 ảnh</span>
                    </div>
                    <div id="previewImages" class="preview-grid mb-4"></div>

                    <div class="action-row d-flex flex-column flex-sm-row gap-2">
                        <button type="submit" class="btn btn-dark">Tạo sản phẩm</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Quay lại danh sách</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const input = document.getElementById('Images');
            const preview = document.getElementById('previewImages');
            const previewCount = document.getElementById('previewCount');

            // CHANGED: xử lý panel danh mục mới
            const toggleNewCategoryBtn = document.getElementById('toggleNewCategoryBtn');
            const newCategoryPanel = document.getElementById('newCategoryPanel');
            const newCategoryNameInput = document.getElementById('NewCategoryName');
            const categorySelect = document.getElementById('CategoryId');

            const emptyState = () => {
                preview.innerHTML = `
                    <div class="preview-box d-flex align-items-center justify-content-center" style="min-height: 170px;">
                        <div class="text-center text-muted px-3">
                            Chưa có ảnh nào được chọn.
                        </div>
                    </div>
                `;
                previewCount.textContent = '0 ảnh';
            };

            emptyState();

            input?.addEventListener('change', function (e) {
                const files = Array.from(e.target.files || []);
                preview.innerHTML = '';
                previewCount.textContent = `${files.length} ảnh`;

                if (!files.length) {
                    emptyState();
                    return;
                }

                files.forEach(file => {
                    const reader = new FileReader();
                    reader.onload = function (event) {
                        const item = document.createElement('div');
                        item.className = 'preview-box';
                        item.innerHTML = `
                            <img src="${event.target.result}" alt="Ảnh xem trước" />
                            <div class="preview-caption" title="${file.name}">${file.name}</div>
                        `;
                        preview.appendChild(item);
                    };
                    reader.readAsDataURL(file);
                });
            });

            toggleNewCategoryBtn?.addEventListener('click', function () {
                const isHidden = newCategoryPanel.style.display === 'none' || newCategoryPanel.style.display === '';
                newCategoryPanel.style.display = isHidden ? 'block' : 'none';

                if (isHidden) {
                    newCategoryNameInput?.focus();
                }
            });

            // CHANGED: nếu người dùng nhập danh mục mới thì tự bỏ chọn dropdown cũ
            newCategoryNameInput?.addEventListener('input', function () {
                if (this.value.trim() !== '' && categorySelect) {
                    categorySelect.value = '';
                }
            });
        });
    </script>
}
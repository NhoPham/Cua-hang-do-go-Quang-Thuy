@model QLBH.Models.Product
@using QLBH.Utils

@{
    ViewData["Title"] = "Chỉnh sửa sản phẩm";
    var imageList = ImageHelper.GetImageList(Model.Images);
}

<style>
    .product-editor-page {
        --wood-950: #241913;
        --wood-900: #2f2219;
        --wood-800: #4c392b;
        --wood-700: #6f533d;
        --wood-500: #b89268;
        --wood-300: #eadac8;
        --wood-200: #f6ede5;
        --wood-100: #fbf7f2;
        --wood-border: #e7d9ca;
        --wood-text: #4f3d2f;
        --wood-muted: #8f7b67;
    }

    .product-editor-page .editor-hero {
        position: relative;
        overflow: hidden;
        border-radius: 30px;
        padding: 1.8rem;
        background: linear-gradient(135deg, rgba(36,25,19,.98), rgba(79,59,43,.92));
        color: #fff;
        box-shadow: 0 22px 54px rgba(36,25,19,.16);
    }

    .product-editor-page .editor-hero::after {
        content: "";
        position: absolute;
        right: -24px;
        bottom: -34px;
        width: 140px;
        height: 140px;
        border-radius: 50%;
        background: rgba(255,255,255,.06);
    }

    .product-editor-page .editor-kicker,
    .product-editor-page .editor-chip {
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        padding: .55rem .95rem;
        border-radius: 999px;
        font-weight: 600;
        font-size: .92rem;
    }

    .product-editor-page .editor-kicker {
        background: rgba(255,255,255,.08);
        border: 1px solid rgba(255,255,255,.08);
        color: #f6e7d6;
    }

    .product-editor-page .editor-title {
        font-size: clamp(2rem, 4vw, 3rem);
        line-height: 1.1;
        font-weight: 800;
        letter-spacing: -.03em;
    }

    .product-editor-page .editor-desc {
        color: rgba(255,255,255,.76);
        line-height: 1.8;
        margin-bottom: 0;
    }

    .product-editor-page .editor-panel,
    .product-editor-page .side-panel,
    .product-editor-page .image-card,
    .product-editor-page .preview-box,
    .product-editor-page .metric-card {
        border-radius: 26px;
        border: 1px solid var(--wood-border);
        background: #fff;
        box-shadow: 0 14px 34px rgba(36,25,19,.07);
    }

    .product-editor-page .editor-panel,
    .product-editor-page .side-panel {
        padding: 1.5rem;
    }

    .product-editor-page .side-panel {
        background: linear-gradient(135deg, #fff, var(--wood-100));
        height: 100%;
    }

    .product-editor-page .editor-chip {
        background: var(--wood-200);
        color: var(--wood-text);
    }

    .product-editor-page .panel-title,
    .product-editor-page .form-label,
    .product-editor-page .metric-title {
        color: var(--wood-text);
    }

    .product-editor-page .panel-title {
        font-size: 1.2rem;
        font-weight: 800;
        margin-bottom: .35rem;
    }

    .product-editor-page .panel-text,
    .product-editor-page .metric-text,
    .product-editor-page .form-text {
        color: var(--wood-muted);
        line-height: 1.75;
    }

    .product-editor-page .metric-card {
        padding: 1rem;
        background: rgba(246,237,229,.55);
    }

    .product-editor-page .metric-title {
        font-size: .88rem;
        font-weight: 700;
        margin-bottom: .35rem;
    }

    .product-editor-page .metric-value {
        color: var(--wood-900);
        font-size: 1.1rem;
        font-weight: 800;
    }

    .product-editor-page .form-label {
        font-weight: 700;
        margin-bottom: .55rem;
    }

    .product-editor-page .form-control,
    .product-editor-page .form-select {
        min-height: 52px;
        border-radius: 16px;
        border: 1px solid #d6c6b6;
        background: #fffefc;
        box-shadow: none;
    }

    .product-editor-page textarea.form-control {
        min-height: 140px;
    }

    .product-editor-page .form-control:focus,
    .product-editor-page .form-select:focus {
        border-color: var(--wood-500);
        box-shadow: 0 0 0 .15rem rgba(184,146,104,.18);
    }

    .product-editor-page .upload-box {
        border: 1.5px dashed #d6c6b6;
        border-radius: 22px;
        padding: 1.1rem;
        background: linear-gradient(135deg, var(--wood-100), #fff);
    }

    .product-editor-page .image-grid,
    .product-editor-page .preview-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
        gap: 1rem;
    }

    .product-editor-page .image-card,
    .product-editor-page .preview-box {
        overflow: hidden;
    }

    .product-editor-page .image-card img,
    .product-editor-page .preview-box img {
        width: 100%;
        height: 170px;
        object-fit: cover;
        display: block;
    }

    .product-editor-page .image-caption,
    .product-editor-page .preview-caption {
        padding: .7rem .8rem;
        font-size: .9rem;
        color: var(--wood-muted);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        background: #fff;
    }

    .product-editor-page .action-row .btn {
        min-width: 180px;
        border-radius: 16px;
        padding: .9rem 1.2rem;
        font-weight: 700;
    }

    @@media (max-width: 767.98px) {
        .product-editor-page .editor-hero,
        .product-editor-page .editor-panel,
        .product-editor-page .side-panel {
            padding: 1.2rem;
        }

        .product-editor-page .action-row .btn {
            width: 100%;
        }
    }
</style>

<div class="product-editor-page py-4">
    <section class="editor-hero mb-4">
        <div class="row align-items-center g-4 position-relative">
            <div class="col-lg-8">
                <div class="editor-kicker mb-3">
                    <span>•</span>
                    <span>Quản trị sản phẩm</span>
                </div>
                <h1 class="editor-title mb-3">Chỉnh sửa sản phẩm</h1>
                <p class="editor-desc">
                    Cập nhật thông tin, giá bán, tồn kho và bộ ảnh của sản phẩm theo cùng một ngôn ngữ giao diện với toàn hệ thống.
                </p>
            </div>
            <div class="col-lg-4">
                <div class="d-flex flex-wrap gap-2 justify-content-lg-end">
                    <span class="editor-chip">Ảnh hiện tại</span>
                    <span class="editor-chip">Preview ảnh mới</span>
                    <span class="editor-chip">Form đồng bộ</span>
                </div>
            </div>
        </div>
    </section>

    <form asp-action="Edit" enctype="multipart/form-data" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-4"></div>

        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="Images" />

        <div class="row g-4">
            <div class="col-lg-5">
                <div class="side-panel mb-4">
                    <h4 class="panel-title mb-1">Ảnh hiện tại</h4>
                    <p class="panel-text mb-3">Danh sách ảnh đang được lưu cho sản phẩm này.</p>

                    @if (imageList.Any())
                    {
                        <div class="image-grid">
                            @for (var i = 0; i < imageList.Count; i++)
                            {
                                <div class="image-card">
                                    <img src="@imageList[i]" alt="Ảnh sản phẩm @(i + 1)" />
                                    <div class="image-caption">Ảnh hiện tại @(i + 1)</div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="metric-card text-center text-muted">Chưa có hình ảnh hiện tại.</div>
                    }
                </div>

                <div class="side-panel">
                    <h4 class="panel-title mb-3">Thông tin hiện tại</h4>
                    <div class="row g-3">
                        <div class="col-12">
                            <div class="metric-card">
                                <div class="metric-title">Tên sản phẩm hiện tại</div>
                                <div class="metric-value">@Model.Name</div>
                            </div>
                        </div>
                        <div class="col-md-6 col-lg-12">
                            <div class="metric-card">
                                <div class="metric-title">Giá hiện tại</div>
                                <div class="metric-value">@Model.Price.ToString("N0") đ</div>
                                <div class="metric-text mt-1">Mức giá đang hiển thị trên hệ thống.</div>
                            </div>
                        </div>
                        <div class="col-md-6 col-lg-12">
                            <div class="metric-card">
                                <div class="metric-title">Tồn kho hiện tại</div>
                                <div class="metric-value">@Model.Stock</div>
                                <div class="metric-text mt-1">Số lượng sẵn sàng bán của sản phẩm.</div>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="metric-card">
                                <div class="metric-title">Số lượng ảnh</div>
                                <div class="metric-value">@imageList.Count ảnh</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="editor-panel">
                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
                        <div>
                            <h4 class="panel-title mb-1">Cập nhật thông tin sản phẩm</h4>
                            <p class="panel-text mb-0">Điền lại dữ liệu nếu cần thay đổi tên, mô tả, giá, tồn kho, danh mục hoặc ảnh.</p>
                        </div>
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-4 px-4">Quay lại danh sách</a>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Tên sản phẩm</label>
                        <input asp-for="Name" class="form-control" placeholder="Nhập tên sản phẩm" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Mô tả sản phẩm</label>
                        <textarea asp-for="Description" class="form-control" placeholder="Nhập mô tả sản phẩm"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Price" class="form-label">Giá bán</label>
                            <input asp-for="Price" class="form-control" placeholder="Nhập giá sản phẩm" />
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Stock" class="form-label">Số lượng tồn kho</label>
                            <input asp-for="Stock" class="form-control" placeholder="Nhập số lượng tồn kho" />
                            <span asp-validation-for="Stock" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mt-3 mb-3">
                        <label asp-for="CategoryId" class="form-label">Danh mục sản phẩm</label>
                        <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId">
                            <option value="">-- Chọn danh mục --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>

                    <div class="upload-box mb-3">
                        <label for="NewImages" class="form-label">Chọn hình ảnh mới</label>
                        <input type="file" id="NewImages" name="NewImages" class="form-control" multiple accept="image/*" />
                        <div class="form-text mt-2">Nếu không chọn ảnh mới, hệ thống sẽ giữ nguyên ảnh hiện tại.</div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="fw-bold mb-0" style="color: var(--wood-text);">Xem trước ảnh mới</h6>
                        <span id="previewCount" class="badge rounded-pill text-bg-dark">0 ảnh</span>
                    </div>
                    <div id="previewImages" class="preview-grid mb-4"></div>

                    <div class="action-row d-flex flex-column flex-sm-row gap-2">
                        <button type="submit" class="btn btn-dark">Cập nhật sản phẩm</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const input = document.getElementById('NewImages');
            const preview = document.getElementById('previewImages');
            const previewCount = document.getElementById('previewCount');

            const emptyState = () => {
                preview.innerHTML = `
                    <div class="metric-card d-flex align-items-center justify-content-center text-muted" style="min-height: 170px;">
                        Chưa chọn ảnh mới.
                    </div>
                `;
                previewCount.textContent = '0 ảnh';
            };

            emptyState();

            input?.addEventListener('change', function (e) {
                const files = Array.from(e.target.files || []);
                preview.innerHTML = '';
                previewCount.textContent = `${files.length} ảnh`;

                if (!files.length) {
                    emptyState();
                    return;
                }

                files.forEach(file => {
                    const reader = new FileReader();
                    reader.onload = function (event) {
                        const item = document.createElement('div');
                        item.className = 'preview-box';
                        item.innerHTML = `
                            <img src="${event.target.result}" alt="Ảnh xem trước" />
                            <div class="preview-caption" title="${file.name}">${file.name}</div>
                        `;
                        preview.appendChild(item);
                    };
                    reader.readAsDataURL(file);
                });
            });
        });
    </script>
}
